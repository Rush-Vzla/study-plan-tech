---
interface Props {
  unit: string;
}
const { unit } = Astro.props;
---

<section class="checkpoint">
  <header class="checkpoint__header">
    <h3 class="checkpoint__title">✓ Checkpoint — {unit}</h3>
    <p class="checkpoint__desc">
      Responde las preguntas y verifica que los tests del lab pasen antes de avanzar.
    </p>
  </header>
  <div class="checkpoint__body">
    <slot />
  </div>
</section>

<style>
  .checkpoint {
    border: 1px solid var(--sl-color-gray-4);
    background: var(--sl-color-gray-6);
    padding: 1rem 1.25rem;
    margin: 2rem 0;
    border-radius: 6px;
  }
  .checkpoint__title {
    margin: 0 0 0.25rem;
    font-size: 1.125rem;
  }
  .checkpoint__desc {
    margin: 0 0 1rem;
    font-size: 0.875rem;
    color: var(--sl-color-gray-2);
  }
</style>
