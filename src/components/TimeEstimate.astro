---
interface Props {
  hours: number;
}
const { hours } = Astro.props;
---

<span class="time-estimate">~{hours} hs</span>

<style>
  .time-estimate {
    display: inline-block;
    background: color-mix(in srgb, var(--sl-color-accent) 15%, transparent);
    color: var(--sl-color-accent-high);
    border: 1px solid var(--sl-color-accent-low);
    padding: 0.125rem 0.625rem;
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.6;
    vertical-align: middle;
  }
</style>
